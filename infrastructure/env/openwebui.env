############################################
# CORE CONFIG
############################################
WEBUI_NAME=OpenWebUI
ENABLE_PERSISTENT_CONFIG=True

############################################
# AUTH & USERS
############################################
ENABLE_SIGNUP=True
ADMIN_EMAIL=admin@email.com
DEFAULT_USER_ROLE=user

############################################
# API / PIPELINES INTEGRATION
############################################
ENABLE_OPENAI_API=True
OPENAI_API_BASE_URL=http://pipelines:9099
OPENAI_API_KEY=0p3n-w3bu!

############################################
# DATABASE (PostgreSQL normal)
############################################
DATABASE_TYPE=postgresql
DATABASE_HOST=db
DATABASE_NAME=owebuidb
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_URL=postgresql://user:password@db/owebuidb

############################################
# VECTOR DATABASE (pgvector)
############################################
VECTOR_DB=pgvector
PGVECTOR_DB_URL=postgresql://user:password@vdb/pgvdb
PGVECTOR_CREATE_EXTENSION=true

############################################
# OLLAMA (LLM)
############################################
OLLAMA_BASE_URL=http://ollama:11434

############################################
# RAG CONFIG
############################################
RAG_EMBEDDING_ENGINE=ollama
# RAG_EMBEDDING_MODEL=bge-m3:567m   # opcional si querés cambiar modelo
# RAG_EMBEDDING_BATCH_SIZE=1

############################################
# FEATURES (recomendado)
